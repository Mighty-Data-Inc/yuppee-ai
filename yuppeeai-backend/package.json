{
  "name": "yuppee-ai-backend",
  "version": "0.2.0-alpha.2",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "api:local": "npm run build && node dist/localApi.js",
    "api:local:start": "node dist/localApi.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "deploy": "npm run build && npx firebase-tools deploy --config ../firebase.json --only functions",
    "seed:tiers": "node scripts/seedTiers.js",
    "view:tiers": "node scripts/viewTiers.js",
    "create:tier": "node scripts/createTier.js",
    "delete:tier": "node scripts/deleteTier.js",
    "set:user-tier": "node scripts/setUserTier.js",
    "set:user-period-usage": "node scripts/setUserPeriodUsage.js",
    "view:user": "node scripts/viewUser.js"
  },
  "dependencies": {
    "@mightydatainc/llm-conversation": "^1.0.6",
    "@yuppee-ai/contracts": "file:../packages/yuppeeai-contracts",
    "dotenv": "^17.3.1",
    "firebase-admin": "^10.3.0",
    "firebase-functions": "^4.9.0",
    "openai": "^6.32.0",
    "vite": "8.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "firebase-tools": "^15.13.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.3"
  }
}
