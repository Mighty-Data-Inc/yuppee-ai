{
  "name": "yuppee-ai-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "typecheck": "npm run typecheck:app && npm run typecheck:test",
    "typecheck:app": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "api:local": "npm run build && node dist/localApi.js",
    "api:local:start": "node dist/localApi.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.400.0",
    "@aws-sdk/lib-dynamodb": "^3.400.0",
    "@mightydatainc/llm-conversation": "^1.0.6",
    "dotenv": "^17.3.1",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "glob": "^13.0.6",
    "test-exclude": "^8.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  }
}
