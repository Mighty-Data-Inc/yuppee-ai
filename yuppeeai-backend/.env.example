# AWS Configuration
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=yuppee-preferences

# Search Provider (e.g. Google Custom Search, Bing, SerpAPI)
SEARCH_PROVIDER_API_KEY=your_search_api_key_here
SEARCH_PROVIDER_ENGINE_ID=your_engine_id_here

# LLM for widget generation (e.g. OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
