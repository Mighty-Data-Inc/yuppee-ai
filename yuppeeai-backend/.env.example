# AWS Configuration
AWS_REGION=us-east-1

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Firebase Admin SDK Configuration
# For local development: Download your Firebase Service Account Key from Firebase Console
# Project Settings → Service Accounts → Generate new private key
# Save it and reference the path below (optional - for local testing)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# Firebase Project ID (available from Firebase Console)
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Optional: Firebase Admin also checks this variable for token verification project context.
# If omitted, backend maps FIREBASE_PROJECT_ID -> GOOGLE_CLOUD_PROJECT automatically.
GOOGLE_CLOUD_PROJECT=

# For AWS Lambda deployment, Firebase Admin SDK will use Application Default Credentials
# Ensure the Lambda execution role has access to Firebase Authentication

