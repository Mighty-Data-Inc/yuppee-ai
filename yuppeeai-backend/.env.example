# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Firebase Admin SDK Configuration
# For local development: Download your Firebase Service Account Key from Firebase Console
# Project Settings → Service Accounts → Generate new private key
# Save it and reference the path below (optional - for local testing)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# Firebase Project ID (available from Firebase Console)
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Optional: Firebase Admin also checks this variable for token verification project context.
# If omitted, backend maps FIREBASE_PROJECT_ID -> GOOGLE_CLOUD_PROJECT automatically.
GOOGLE_CLOUD_PROJECT=

# For Firebase Cloud Functions deployment, Firebase Admin SDK will use Application Default
# Credentials provided by the Cloud Functions runtime — no service account key needed.

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APP_URL=

# Stripe recurring monthly price IDs by tier
STRIPE_PRICE_TIER_BASIC=
STRIPE_PRICE_TIER_STANDARD=
STRIPE_PRICE_TIER_PRO=
STRIPE_PRICE_TIER_ENTERPRISE=

