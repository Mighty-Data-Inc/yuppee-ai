{
  "hosting": [
    {
      "target": "yuppee-ai-frontend",
      "public": "yuppeeai-frontend/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "package-lock.json",
        "npm-shrinkwrap.json"
      ],
      "predeploy": [
        "node packages/yuppeeai-contracts/build-and-install.js",
        "npm --prefix yuppeeai-frontend run build"
      ]
    }
  ],
  "functions": [
    {
      "source": "yuppeeai-backend",
      "codebase": "backend",
      "runtime": "nodejs24",
      "env": ["OPENAI_MODEL=gpt-4o-mini"],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "package-lock.json",
        "npm-shrinkwrap.json"
      ],
      "predeploy": [
        "node packages/yuppeeai-contracts/build-and-install.js",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ]
}
