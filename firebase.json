{
  "hosting": [
    {
      "target": "yuppee-ai-frontend",
      "public": "yuppeeai-frontend/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "package-lock.json",
        "npm-shrinkwrap.json"
      ],
      "rewrites": [
        {
          "source": "/api/search",
          "function": {
            "functionId": "search",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/refine",
          "function": {
            "functionId": "refine",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/inflightmsg",
          "function": {
            "functionId": "inflightmsg",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/usage",
          "function": {
            "functionId": "usage",
            "region": "us-central1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "predeploy": [
        "node packages/yuppeeai-contracts/build-and-install.js",
        "npm --prefix yuppeeai-frontend run build"
      ]
    }
  ],
  "functions": [
    {
      "source": "yuppeeai-backend",
      "codebase": "backend",
      "runtime": "nodejs24",
      "env": ["OPENAI_MODEL=gpt-4o-mini"],
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "package-lock.json",
        "npm-shrinkwrap.json"
      ],
      "predeploy": [
        "node packages/yuppeeai-contracts/build-and-install.js",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ]
}
