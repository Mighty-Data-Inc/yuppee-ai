{
  "functions": [
    {
      "source": "yuppeeai-backend",
      "codebase": "backend",
      "runtime": "nodejs24",
      "env": ["OPENAI_MODEL=gpt-4o-mini"],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "package-lock.json",
        "npm-shrinkwrap.json"
      ],
      "predeploy": [
        "node yuppeeai-backend/build-contracts.js",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ]
}
